{
  "rewrites": [
    {
      "source": "/api/(.*)", 
      "destination": "/api/server.js"
    },
    {
      "source": "/(.*)", 
      "destination": "/index.html"
    }
  ],
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ]
}
